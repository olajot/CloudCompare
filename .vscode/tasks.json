{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build qSegmenter (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build-debug",
        "--target",
        "qSegmenter",
        "--parallel",
        "7"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Build qSegmenter (Release)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build-release",
        "--target",
        "qSegmenter",
        "--parallel",
        "7"
      ],
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}